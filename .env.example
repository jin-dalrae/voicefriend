# Copy this file to .env, then fill in your key:   cp .env.example .env
# Get a free Gemini API key from Google AI Studio:  https://aistudio.google.com/apikey
# This uses the Gemini Developer API (Google AI), NOT Vertex AI.

# Required — your Gemini API key
GEMINI_API_KEY=

# Optional overrides (defaults shown)
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
# LUC_VOICE=Puck
# JEENIE_VOICE=Kore
# PORT=3000

# Local data behavior (defaults are fine)
# LOG_TO_FILE=1       # save transcripts to data/transcript.jsonl
# LOG_TRANSCRIPTS=0   # also print transcripts in the console
# REMEMBER=1          # remember you across sessions in data/profile.json
